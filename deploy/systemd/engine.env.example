# Environment for turbodb-engine.service. Install as /etc/turbodb/engine.env
# (mode 0640, owner root:turbodb).
#
# Extra flags appended to ExecStart, e.g. admin mTLS:
# TURBODB_ENGINE_EXTRA_FLAGS=--admin-tls-cert /etc/turbodb/tls/server.crt --admin-tls-key /etc/turbodb/tls/server.key --admin-tls-ca /etc/turbodb/tls/ca.crt
TURBODB_ENGINE_EXTRA_FLAGS=
